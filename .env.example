# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Better Auth social provider + Calendar API)
# Scopes required: openid, email, profile, https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (Postgres)
# Use the pooled connection string for Better Auth / app queries
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
# Supabase renamed the anon key to "publishable key" in 2025
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Places (venue lookup)
GOOGLE_PLACES_API_KEY=

# Twilio WhatsApp sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
