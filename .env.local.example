# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google (Better Auth fills GOOGLE_ACCESS_TOKEN per-session) ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kapso / WhatsApp ──────────────────────────────────────────────────────────
# Base URL for Kapso API (no trailing slash)
KAPSO_API_BASE_URL=https://api.kapso.ai
# API key from https://app.kapso.ai → Settings → API Keys
KAPSO_API_KEY=
# Sandbox phone number ID (from `kapso whatsapp numbers list`)
WHATSAPP_PHONE_NUMBER_ID=597907523413541
# A random secret you choose — used in the Kapso webhook "verify_token" field
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Vercel Cron auth ──────────────────────────────────────────────────────────
# A random secret to protect the trigger-nudge endpoint when called by cron
CRON_SECRET=

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
